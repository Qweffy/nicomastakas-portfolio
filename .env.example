# Canonical site URL — drives metadata, OG images, sitemap, robots.
# Real values go in .env.local (gitignored) or the Vercel dashboard.
NEXT_PUBLIC_SITE_URL=https://nicomastakas.com

# ── First-party analytics (server-only secrets) ──
# Neon Postgres connection string. Create a free project at neon.tech, or add the
# Postgres/Neon integration from the Vercel dashboard (which sets this automatically).
DATABASE_URL=
# Long random string — salt for the cookieless daily visitor hash (no IP is ever stored).
ANALYTICS_SALT=
# Password to open the private /dashboard.
DASHBOARD_PASSWORD=
# Long random string — signs the admin session cookie for /dashboard.
DASHBOARD_SECRET=
